{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "default_agent": "build",
  "instructions": [".opencode/AGENTS.md"],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "@ibraheem4/linear-mcp@latest"],
      "environment": {
        "LINEAR_API_KEY": "{env:LINEAR_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://192.168.1.105:1234/v1",
        "timeout": 1200000,
        "chunkTimeout": 600000
      },
      "models": {
        "qwen3-coder-30b": {
          "name": "Qwen3 Coder 30B"
        },
        "qwen3.5-35b-a3b": {
          "name": "Qwen3.5 35B-A3B"
        },
        "qwen3.5-27b-claude-4.6-opus-reasoning-distilled" :{
          "name" : "qwen3.5 27b claude-4.6-opus reasoning distilled"
        },
        "gpt-oss-20b" : {
          "name" : "gpt-oss-20b"
        }
      }
    }
  },
  "compaction": {
    "auto": false
  },
  "permission": {
    "*": "allow",
    "edit": "allow",
    "bash": "allow",
    "task": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "deny",
          "sdlc-coordinator": "allow",
          "sdlc-engineering": "allow",
          "sdlc-planner": "allow"
        }
      }
    }
  }
}
