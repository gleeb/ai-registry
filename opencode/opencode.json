{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "default_agent": "build",
  "instructions": [".opencode/AGENTS.md"],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "@ibraheem4/linear-mcp@latest"],
      "environment": {
        "LINEAR_API_KEY": "{env:LINEAR_API_KEY}"
      }
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://192.168.1.105:1234/v1"
      },
      "models": {
        "qwen3-coder-30b": {
          "name": "qwen3-coder-30b"
        },
        "qwen3.5-35b-a3b": {
          "name": "qwen3.5-35b-a3b"
        }
      }
    }
  },
  "permission": {
    "*": "allow",
    "edit": "allow",
    "bash": "allow",
    "task": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "sdlc-coordinator": "allow",
          "sdlc-architect": "allow",
          "sdlc-planner": "allow",
          "sdlc-project-research": "allow",
          "*": "deny"
        }
      }
    },
    "sdlc-coordinator": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "sdlc-planner": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "sdlc-architect": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    }
  }
}
